{
  "name": "tuniinvoice-pro",
  "version": "1.0.0",
  "description": "Tunisian Invoice Generator - Desktop Edition",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "clean": "rm -rf dist",
    "build": "electron-builder",
    "build:win": "npm run clean && electron-builder --win",
    "build:mac": "npm run clean && electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "electron-updater": "^6.1.7",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.tuniinvoice.pro",
    "publish": [
      {
        "provider": "github",
        "owner": "a32116150-ctrl",
        "repo": "tuninvoice"
      }
    ],
    "productName": "TuniInvoice Pro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}